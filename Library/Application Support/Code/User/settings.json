{
  "explorer.confirmDragAndDrop": false,
  "editor.guides.indentation": false,
  "editor.lightbulb.enabled": "off",
  "workbench.colorTheme": "Gruvbox Dark Medium",
  "search.mode": "newEditor",
  "workbench.startupEditor": "none",
  "explorer.autoReveal": false,
  "editor.autoClosingBrackets": "never",
  "editor.occurrencesHighlight": "off",
  "editor.codeLens": false,
  "workbench.editor.showIcons": false,
  "explorer.compactFolders": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.activityBar.location": "hidden",
  "window.zoomLevel": 2,
  "editor.fontFamily": "Mononoki",
  "search.quickOpen.includeHistory": false,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "files.saveConflictResolution": "overwriteFileOnDisk",
  "js/ts.updateImportsOnFileMove.enabled": "never",
  "editor.lineHeight": 1.4,
  "workbench.editor.enablePreview": false,
  "editor.autoClosingQuotes": "never",
  "editor.fontSize": 14,
  "html.autoClosingTags": false,
  "js/ts.tsserver.log": "off",
  "js/ts.autoClosingTags.enabled": false,
  "eslint.debug": true,
  "eslint.ignoreUntitled": true,
  "workbench.colorCustomizations": {
    // "editorError.background": "#ff000099"
    "editorError.border": "#ff000099",
  },
  "js/ts.preferences.quoteStyle": "double",
  "update.mode": "none",
  "editor.stickyScroll.enabled": false,
  "editor.colorDecorators": false,
  "html.autoCreateQuotes": false,
  "editor.tabSize": 2,
  "extensions.autoCheckUpdates": false,
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://unpkg.com/knip%406/schema.json": true,
    "https://www.schemastore.org/": true,
  },
}
